# ─────────────────────────────────────────────────────────────────────────────
# borsa — environment variable reference
# Copy to .env and fill in the values you need.
# Providers with no key are automatically excluded from the fetcher chain.
# ─────────────────────────────────────────────────────────────────────────────

# ── /v1 endpoints — user-supplied keys ───────────────────────────────────────
# These are YOUR keys. They never leave your server.

# Alpha Vantage free tier: 25 req/day — https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# Finnhub free tier: 60 req/min — https://finnhub.io/register
FINNHUB_KEY=

# ── /demo endpoint — operator-supplied keys ───────────────────────────────────
# Keys used by the public demo widget. Separate from user keys so you can
# apply stricter rate limits without affecting authenticated users.

DEMO_ALPHA_VANTAGE_KEY=
DEMO_FINNHUB_KEY=

# ── Demo rate limit ───────────────────────────────────────────────────────────
# Global requests/day cap for the /demo endpoint (default: 50)
DEMO_DAILY_LIMIT=50

# ── Cache ─────────────────────────────────────────────────────────────────────
# TTL in seconds for /v1 quotes (default: 300)
CACHE_TTL_SECONDS=300
# TTL in seconds for /demo quotes (default: 600)
DEMO_CACHE_TTL_SECONDS=600
# Maximum cached entries (default: 512)
CACHE_MAX_SIZE=512
# Fetch all /v1 quotes when the app starts (default: true)
FETCH_QUOTES_ON_STARTUP=true
# Refresh all /v1 quotes every CACHE_TTL_SECONDS (default: true)
AUTO_REFRESH_QUOTES=true
# Enable unofficial Yahoo Finance/yfinance fetching. Review Yahoo/yfinance terms first.
ENABLE_YAHOO_FINANCE=false

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: debug | info | warning | error
LOG_LEVEL=info
# Set to true for pretty coloured console output (development only)
DEV_MODE=false

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated origins, or * for all. Default: *
# CORS_ORIGINS=https://your-frontend.com
